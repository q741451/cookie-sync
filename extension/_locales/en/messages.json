{
  "extName": {
    "message": "Cookie Channel Sync"
  },
  "extDescription": {
    "message": "Manually sync cookies for the current site to your own server, grouped by channel."
  },
  "popup_uploadBtn": {
    "message": "⬆️ Upload cookies for this site"
  },
  "popup_downloadBtn": {
    "message": "⬇️ Download cookies for this site"
  },
  "popup_settingsBtn": {
    "message": "Settings: server / channel"
  },
  "popup_notWebPage": {
    "message": "This isn't a regular web page — cookies can't be read here."
  },
  "popup_noChannelHint": {
    "message": "No channel available yet. Click \"Settings\" below to create or join one."
  },
  "popup_currentSite": {
    "message": "Current site: $SITE$",
    "placeholders": {
      "site": {
        "content": "$1"
      }
    }
  },
  "popup_usingChannelDefault": {
    "message": "Using channel: $LABEL$ (default)\nServer: $SERVER$",
    "placeholders": {
      "label": {
        "content": "$1"
      },
      "server": {
        "content": "$2"
      }
    }
  },
  "popup_usingChannelRule": {
    "message": "Using channel: $LABEL$ (matched by rule)\nServer: $SERVER$",
    "placeholders": {
      "label": {
        "content": "$1"
      },
      "server": {
        "content": "$2"
      }
    }
  },
  "popup_cannotGetSite": {
    "message": "Couldn't read info about the current site."
  },
  "popup_needSetup": {
    "message": "No channel available — please finish setup first."
  },
  "popup_uploading": {
    "message": "Uploading..."
  },
  "popup_downloading": {
    "message": "Downloading..."
  },
  "popup_uploadSuccess": {
    "message": "Uploaded $COUNT$ cookie(s) (channel: $LABEL$)",
    "placeholders": {
      "count": {
        "content": "$1"
      },
      "label": {
        "content": "$2"
      }
    }
  },
  "popup_uploadFailed": {
    "message": "Upload failed: $ERROR$",
    "placeholders": {
      "error": {
        "content": "$1"
      }
    }
  },
  "popup_downloadFailed": {
    "message": "Download failed: $ERROR$",
    "placeholders": {
      "error": {
        "content": "$1"
      }
    }
  },
  "popup_restoreSuccess": {
    "message": "Restored $OK$/$TOTAL$ cookie(s)\n(channel: $LABEL$, last updated $TIME$)",
    "placeholders": {
      "ok": {
        "content": "$1"
      },
      "total": {
        "content": "$2"
      },
      "label": {
        "content": "$3"
      },
      "time": {
        "content": "$4"
      }
    }
  },
  "popup_requestError": {
    "message": "Request failed: $ERROR$",
    "placeholders": {
      "error": {
        "content": "$1"
      }
    }
  },
